{
  "name": "invincible-agent-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:convex\"",
    "dev:web": "node ./node_modules/vite/bin/vite.js",
    "dev:convex": "node ./node_modules/convex/bin/main.js dev",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "lint": "eslint . --max-warnings=0",
    "check": "node ./node_modules/typescript/bin/tsc -b --pretty false"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.90",
    "@langchain/langgraph": "^1.0.8",
    "convex": "^1.30.0",
    "lucide-react": "^0.468.0",
    "openai": "^4.86.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/xlsx": "^0.0.36",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.0.7"
  }
}
